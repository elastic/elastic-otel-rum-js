{
  "name": "@elastic/opentelemetry-browser",
  "version": "1.0.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "opentelemetry",
    "telemetry",
    "apm",
    "tracing",
    "metrics",
    "logs",
    "rum",
    "browser"
  ],
  "files": [
    "lib",
    "build",
    "types"
  ],
  "main": "./lib/index.js",
  "types": "./types/index.d.ts",
  "scripts": {
    "clean": "rm -rf build",
    "watch": "node ../../scripts/watch.mjs ./lib npm run build",
    "build:iife": "esbuild ./lib/bundle.js --bundle --conditions=esnext,module --sourcemap --platform=browser --target=es2022 --outfile=build/elastic-otel-browser.js",
    "build:min": "esbuild ./lib/bundle.js --bundle --conditions=esnext,module --minify --sourcemap --platform=browser --target=es2022 --outfile=build/elastic-otel-browser.min.js",
    "build": "npm run build:iife && npm run build:min",
    "gen:types": "rm -rf types && tsc # TODO: would be nice to tree-shake the *.d.ts files",
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:licenses",
    "lint:eslint": "eslint .",
    "lint:prettier": "(cd ../../; prettier --check $npm_config_local_prefix)",
    "lint:licenses": "../../scripts/gen-notice.sh --lint .",
    "lint:fix": "eslint --fix . && (cd ../../; prettier --list-different --write $npm_config_local_prefix)",
    "lint:ci": " npm run lint:licenses # eslint/prettier ran in repo root",
    "test:smoke": "npm run build && cp build/* ./test/smoke/assets && playwright test",
    "test:unit": "node --test test/unit/*.test.js"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/instrumentation-document-load": "^0.57.0",
    "@opentelemetry/instrumentation-fetch": "^0.213.0",
    "@opentelemetry/instrumentation-long-task": "^0.56.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.56.0",
    "@opentelemetry/instrumentation-web-exception": "^0.5.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.213.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-trace-web": "^2.2.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "esbuild": "0.27.1",
    "ua-parser-js": "^2.0.7"
  }
}
