{
  "name": "@elastic/stack-reframe",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elastic/elastic-otel-rum-js.git",
    "directory": "packages/stack-reframe"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && npm run test:tsx",
    "test:tsx": "for f in ./test/*.spec.ts; do tsx \"$f\"; done",
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:licenses",
    "lint:eslint": "eslint .",
    "lint:prettier": "(cd ../../; prettier --check $npm_config_local_prefix)",
    "lint:licenses": "../../scripts/gen-notice.sh --lint .",
    "lint:fix": "eslint --fix . && (cd ../../; prettier --list-different --write $npm_config_local_prefix)"
  },
  "dependencies": {
    "source-map": "^0.7.6",
    "stacktrace-parser": "^0.1.11"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "5.0.4"
  }
}
